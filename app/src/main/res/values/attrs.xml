<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ChatTheme custom attributes -->
    <declare-styleable name="ChatThemeView">
        <attr name="themeName" format="string" />
        <attr name="themePreview" format="boolean" />
    </declare-styleable>

    <!-- BlobAnimationView -->
    <declare-styleable name="BlobAnimationView">
        <attr name="blobColor" format="color" />
        <attr name="blobSpeed" format="float" />
    </declare-styleable>

    <!-- SmsIllustrationView -->
    <declare-styleable name="SmsIllustrationView">
        <attr name="illustrationColor" format="color" />
    </declare-styleable>
</resources>
