<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="end"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/spacing_sm"
    android:paddingVertical="4dp">
    <TextView
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:layout_gravity="center_horizontal"
        android:tag="dateSeparator"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"/>
    <com.google.android.material.imageview.ShapeableImageView
        android:layout_gravity="end"
        android:id="@+id/imgAttachment"
        android:background="@color/bubble_received_bg"
        android:visibility="gone"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginBottom="2dp"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        app:shapeAppearanceOverlay="@style/ShapeOverlay.AttachmentBubble"/>
    <androidx.cardview.widget.CardView
        android:layout_gravity="end"
        android:id="@+id/cardLinkPreview"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardMaxElevation="2dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="240dp"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/imgLinkPreview"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null"/>
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/surface_card"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:ellipsize="end"
                    android:id="@+id/txtLinkTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:ellipsize="end"
                    android:id="@+id/txtLinkDesc"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="2"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/origin_primary"
                    android:ellipsize="end"
                    android:id="@+id/txtLinkUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="15sp"
        android:textColor="@color/bubble_sent_text"
        android:layout_gravity="end"
        android:id="@+id/txtMessageBody"
        android:background="@drawable/bg_bubble_sent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/bubble_max_width"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"/>
    <TextView
        android:textSize="10sp"
        android:layout_gravity="end"
        android:id="@+id/txtStarIndicator"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:text="⭐"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/imgStarIndicator"
            android:visibility="gone"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_star_filled"
            android:layout_marginEnd="4dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:id="@+id/txtMessageStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="4dp"/>
    </LinearLayout>
</LinearLayout>
