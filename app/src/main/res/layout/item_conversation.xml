<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:id="@+id/itemRoot"
    android:background="@drawable/bg_conversation_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground"
    android:paddingHorizontal="@dimen/spacing_md"
    android:paddingVertical="12dp">
    <FrameLayout
        android:layout_width="@dimen/avatar_size"
        android:layout_height="@dimen/avatar_size">
        <ImageView
            android:id="@+id/imgAvatar"
            android:background="@drawable/bg_avatar_circle"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_person"
            android:contentDescription="@null"
            android:outlineProvider="background"/>
        <ImageView
            android:layout_gravity="end|bottom"
            android:id="@+id/imgLockBadge"
            android:visibility="gone"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_lock"
            android:contentDescription="@null"/>
        <ImageView
            android:id="@+id/imgSelectedCheck"
            android:background="@drawable/bg_avatar_selected_overlay"
            android:padding="10dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_check"
            android:contentDescription="@null"/>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/spacing_md">
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:ellipsize="end"
            android:id="@+id/txtName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:ellipsize="end"
            android:id="@+id/txtSnippet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="end"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:id="@+id/txtTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@+id/txtUnreadBadge"
            android:background="@drawable/bg_unread_badge"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minWidth="20dp"
            android:minHeight="20dp"
            android:paddingHorizontal="6dp"/>
    </LinearLayout>
</LinearLayout>
