<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/bg_surface"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/pinContainer"
        android:padding="@dimen/spacing_lg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_lock"
            android:contentDescription="@null"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:id="@+id/txtDisplayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:id="@+id/txtPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/lock_enter_pin"/>
        <EditText
            android:textSize="28sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:id="@+id/editPin"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:maxLength="8"
            android:inputType="numberPassword"
            android:letterSpacing="0.5"
            android:autofillHints=""/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/error_red"
            android:gravity="center"
            android:id="@+id/txtError"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"/>
        <Button
            android:id="@+id/btnUnlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/action_unlock"
            android:backgroundTint="@color/origin_primary"/>
        <Button
            android:id="@+id/btnUseBiometric"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/lock_use_biometric"
            style="@style/Widget.Material3.Button.TextButton"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/vaultContainer"
        android:background="@color/bg_surface"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.MaterialToolbar xmlns:app="http://schemas.android.com/apk/res-auto"
            android:theme="@style/Theme.OriginSMS"
            android:id="@+id/vaultToolbar"
            android:background="@color/origin_primary"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/section_hidden_chats"
            app:titleTextColor="@android:color/white"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:id="@+id/txtVaultEmpty"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:text="No hidden chats yet.\10Hide a chat from the in-chat 3-dot menu."
            android:layout_weight="1"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerVault"
            android:background="@color/bg_surface"
            android:visibility="gone"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>
</FrameLayout>
