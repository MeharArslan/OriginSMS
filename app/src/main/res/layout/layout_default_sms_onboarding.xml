<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/onboardingRoot"
    android:background="?attr/colorSurface"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.meharenterprises.originsms.ui.BlobAnimationView
        android:id="@+id/blobBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="32dp">
        <com.meharenterprises.originsms.ui.SmsIllustrationView
            android:id="@+id/smsIllustration"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="32dp"
            android:layout_weight="0.45"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="To use OriginSMS, make it your default SMS app."
            android:lineSpacingMultiplier="1.4"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:id="@+id/btnSetDefaultOnboarding"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Set default SMS app"
            app:backgroundTint="@color/origin_primary"
            app:cornerRadius="28dp"
            app:elevation="0dp"/>
    </LinearLayout>
</FrameLayout>
