<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_lock"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/txtDisplayName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:gravity="center"
        android:textColor="@color/text_primary_light"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Ali Raza" />

    <TextView
        android:id="@+id/txtPrompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:gravity="center"
        android:text="@string/lock_enter_pin"
        android:textColor="@color/text_secondary_light"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/editPin"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:autofillHints=""
        android:gravity="center"
        android:inputType="numberPassword"
        android:letterSpacing="0.5"
        android:maxLength="8"
        android:textColor="@color/text_primary_light"
        android:textSize="28sp" />

    <TextView
        android:id="@+id/txtError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:gravity="center"
        android:textColor="@color/error_red"
        android:textSize="13sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnUnlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:backgroundTint="@color/origin_primary"
        android:text="@string/action_unlock" />

    <Button
        android:id="@+id/btnUseBiometric"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/lock_use_biometric"
        android:visibility="gone" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerVault"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:visibility="gone"
        tools:listitem="@layout/item_conversation"
        tools:visibility="visible" />


    <com.google.android.material.appbar.MaterialToolbar android:id="@+id/vaultToolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize" android:visibility="gone" />
    <LinearLayout android:id="@+id/pinContainer"
        android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
    <LinearLayout android:id="@+id/vaultContainer"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:orientation="vertical" android:visibility="gone">
        <TextView android:id="@+id/txtVaultEmpty"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:padding="24dp" android:text="No hidden chats" android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
