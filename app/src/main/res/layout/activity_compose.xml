<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/bg_surface"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.MaterialToolbar
        android:theme="@style/Theme.OriginSMS"
        android:id="@+id/toolbar"
        android:background="@color/origin_primary"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/action_new_message"
        app:titleTextColor="@android:color/white"/>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="10dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="16dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:importantForAccessibility="no"
                android:layout_marginEnd="12dp"
                app:tint="@color/text_secondary"/>
            <EditText
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:id="@+id/editRecipient"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Search contacts or enter number"
                android:maxLines="1"
                android:layout_weight="1"
                android:inputType="text"
                android:autofillHints="phone"/>
            <ImageView
                android:id="@+id/btnClearRecipient"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_close"
                android:importantForAccessibility="no"
                android:layout_marginStart="8dp"
                app:tint="@color/text_secondary"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerContactPicker"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingVertical="@dimen/spacing_sm"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMessages"
            android:visibility="gone"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="@dimen/spacing_md"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_sm"
        android:paddingVertical="6dp">
        <ImageButton
            android:layout_gravity="bottom"
            android:id="@+id/btnAttach"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="2dp"
            android:src="@drawable/ic_attach"
            android:contentDescription="@string/action_attach"/>
        <FrameLayout
            android:layout_gravity="bottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp">
            <EditText
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:id="@+id/editMessage"
                android:background="@drawable/bg_input_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="44dp"
                android:hint="@string/hint_type_message"
                android:maxLines="6"
                android:inputType="textMultiLine"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="48dp"
                android:paddingVertical="@dimen/spacing_sm"
                android:autofillHints=""/>
            <ImageButton
                android:layout_gravity="end|bottom"
                android:id="@+id/btnEmoji"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginBottom="4dp"
                android:src="@drawable/ic_emoji"
                android:contentDescription="@string/action_emoji"
                android:layout_marginEnd="4dp"/>
        </FrameLayout>
        <ImageButton
            android:layout_gravity="bottom"
            android:id="@+id/btnSend"
            android:background="@drawable/bg_send_button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="0dp"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/action_send"/>
    </LinearLayout>
    <androidx.emoji2.emojipicker.EmojiPickerView
        android:id="@+id/emojiPickerView"
        android:background="@color/surface_card"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="280dp"/>
</LinearLayout>
