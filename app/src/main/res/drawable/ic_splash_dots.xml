<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:width="120dp"
            android:height="120dp"
            android:viewportWidth="120"
            android:viewportHeight="120">
            <!-- Speech bubble background -->
            <path
                android:fillColor="@color/origin_primary"
                android:pathData="M60,10 C38,10 20,25 20,43 C20,55 27,65 38,71 L34,92 L56,79 C57.3,79.2 58.6,79.3 60,79.3 C82,79.3 100,64 100,46 C100,28 82,10 60,10 Z" />
            <!-- Dot 1 -->
            <path android:name="dot1"
                android:fillColor="@android:color/white"
                android:pathData="M40,48 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />
            <!-- Dot 2 -->
            <path android:name="dot2"
                android:fillColor="@android:color/white"
                android:pathData="M60,48 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />
            <!-- Dot 3 -->
            <path android:name="dot3"
                android:fillColor="@android:color/white"
                android:pathData="M80,48 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />
        </vector>
    </aapt:attr>
    <target android:name="dot1">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="0"
                android:valueTo="-8"
                android:duration="400"
                android:startOffset="0"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate" />
        </aapt:attr>
    </target>
    <target android:name="dot2">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="0"
                android:valueTo="-8"
                android:duration="400"
                android:startOffset="150"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate" />
        </aapt:attr>
    </target>
    <target android:name="dot3">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="0"
                android:valueTo="-8"
                android:duration="400"
                android:startOffset="300"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/accelerate_decelerate" />
        </aapt:attr>
    </target>
</animated-vector>
