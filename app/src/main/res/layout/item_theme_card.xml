<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="6dp">

    <!-- Mini phone frame -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTheme"
        android:layout_width="140dp"
        android:layout_height="220dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:id="@+id/cardBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Mini toolbar -->
            <LinearLayout
                android:id="@+id/miniToolbar"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:alpha="0.7" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contact"
                    android:textColor="#FFFFFFFF"
                    android:textSize="8sp"
                    android:alpha="0.9" />

            </LinearLayout>

            <!-- Chat area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="6dp">

                <!-- Received msg -->
                <TextView
                    android:id="@+id/bubbleReceived"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:maxWidth="90dp"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="4dp"
                    android:text="Hello! 👋"
                    android:textSize="7sp" />

                <!-- Sent msg -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/bubbleSent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="90dp"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="4dp"
                        android:text="Hi there! 😊"
                        android:textSize="7sp" />

                </LinearLayout>

                <!-- Received msg 2 -->
                <TextView
                    android:id="@+id/bubbleReceived2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="90dp"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="4dp"
                    android:text="How are you?"
                    android:textSize="7sp" />

            </LinearLayout>

            <!-- Mini input bar -->
            <LinearLayout
                android:id="@+id/miniInputBar"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="14dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_input_field"
                    android:alpha="0.4" />

                <View
                    android:id="@+id/miniSendBtn"
                    android:layout_width="16dp"
                    android:layout_height="16dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Theme name -->
    <TextView
        android:id="@+id/txtThemeCardName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:maxLines="2"
        android:textSize="10sp"
        android:textStyle="bold" />

    <!-- Selected check -->
    <TextView
        android:id="@+id/txtThemeSelected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="✓ Applied"
        android:textColor="@color/origin_accent"
        android:textSize="9sp"
        android:visibility="gone" />

</LinearLayout>
