<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">
            <TextView
                android:id="@+id/txtThreadTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />
            <ImageView
                android:id="@+id/imgThreadAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp" />
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <View android:id="@+id/chatBackgroundDrawable"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone" />

        <TextView android:id="@+id/txtTrashViewBanner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="12dp" android:visibility="gone"
            android:background="#1A6200EE" android:textColor="@color/origin_primary" />

        <TextView android:id="@+id/scheduledMsgBanner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="8dp" android:visibility="gone"
            android:background="@color/origin_primary" android:textColor="#FFFFFF" />

        <LinearLayout android:id="@+id/messageSelectionBar"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@color/origin_primary" android:visibility="gone">
            <ImageButton android:id="@+id/btnCloseMessageSelection"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:src="@drawable/ic_close" android:padding="12dp"
                android:tint="#FFFFFF" android:background="?attr/selectableItemBackgroundBorderless" />
            <TextView android:id="@+id/txtMessageSelectionCount"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="16sp" />
            <ImageButton android:id="@+id/btnMessageCopy"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:src="@drawable/ic_copy" android:padding="12dp"
                android:tint="#FFFFFF" android:background="?attr/selectableItemBackgroundBorderless" />
            <ImageButton android:id="@+id/btnMessageStar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:src="@drawable/ic_star" android:padding="12dp"
                android:tint="#FFFFFF" android:background="?attr/selectableItemBackgroundBorderless" />
            <ImageButton android:id="@+id/btnMessageDelete"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:src="@drawable/ic_delete" android:padding="12dp"
                android:tint="#FFFFFF" android:background="?attr/selectableItemBackgroundBorderless" />
            <ImageButton android:id="@+id/btnMessageMore"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:src="@drawable/ic_more_vert" android:padding="12dp"
                android:tint="#FFFFFF" android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <HorizontalScrollView android:id="@+id/attachmentPreviewScroll"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:visibility="gone">
            <LinearLayout android:id="@+id/attachmentPreviewContainer"
                android:layout_width="wrap_content" android:layout_height="72dp"
                android:orientation="horizontal" android:padding="4dp" />
        </HorizontalScrollView>

        <LinearLayout android:id="@+id/simIndicatorRow"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="4dp" android:visibility="gone">
            <TextView android:id="@+id/txtSimLabel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="?android:textColorSecondary" />
        </LinearLayout>

        <LinearLayout android:id="@+id/composeBarRoot"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="4dp" android:background="?attr/colorSurface">
            <ImageButton android:id="@+id/btnEmoji"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_emoji"
                android:background="?attr/selectableItemBackgroundBorderless" />
            <EditText android:id="@+id/editMessage"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="@string/hint_type_message"
                android:minLines="1" android:maxLines="5"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="8dp" android:paddingBottom="8dp"
                android:inputType="textMultiLine|textCapSentences" />
            <ImageButton android:id="@+id/btnAttach"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_attach"
                android:background="?attr/selectableItemBackgroundBorderless" />
            <ImageButton android:id="@+id/btnSend"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_send"
                android:background="@drawable/bg_send_button" />
        </LinearLayout>

        <FrameLayout android:id="@+id/emojiPickerView"
            android:layout_width="match_parent" android:layout_height="250dp"
            android:visibility="gone" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabScrollDown"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="80dp" android:layout_marginEnd="16dp"
        android:src="@drawable/ic_arrow_down"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>