<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.MaterialToolbar
        android:theme="@style/Theme.OriginSMS"
        android:id="@+id/toolbar"
        android:background="@color/origin_primary"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back"
        app:title="Trash"
        app:titleTextColor="@android:color/white"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/selectionBar"
        android:background="@color/origin_primary"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="8dp">
        <ImageButton
            android:id="@+id/btnCloseSelection"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_close"
            android:tint="@android:color/white"
            android:contentDescription="Close"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:id="@+id/txtSelectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="0 selected"
            android:layout_weight="1"
            android:layout_marginStart="8dp"/>
        <ImageButton
            android:id="@+id/btnSelectionRestore"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_restore_all"
            android:tint="@android:color/white"
            android:contentDescription="Restore"/>
        <ImageButton
            android:id="@+id/btnSelectionDelete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_delete_all"
            android:tint="#ffff8080"
            android:contentDescription="Delete permanently"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTrash"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:id="@+id/emptyTrash"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="Trash is empty"
        android:layout_weight="1"/>
</LinearLayout>
