<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootCoordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_surface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/origin_primary"
        android:theme="@style/Theme.OriginSMS"
        app:liftOnScroll="false"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="@string/title_conversations"
            app:titleTextColor="@android:color/white" />

        <LinearLayout
            android:id="@+id/searchBarRow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageButton
                android:id="@+id/btnCloseSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_settings"
                android:src="@drawable/ic_back"
                app:tint="@android:color/white" />

            <EditText
                android:id="@+id/editSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:autofillHints=""
                android:background="@null"
                android:hint="@string/action_search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textColorHint="#CCFFFFFF"
                android:textSize="16sp" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Multi-select contextual action bar, shown when one or more conversations are selected -->
    <LinearLayout
        android:id="@+id/selectionActionBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_gravity="top"
        android:background="@color/origin_primary_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_sm"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageButton
            android:id="@+id/btnCloseSelection"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_settings"
            android:src="@drawable/ic_close_white" />

        <TextView
            android:id="@+id/txtSelectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            tools:text="2" />

        <ImageButton
            android:id="@+id/btnSelectionPin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_pin_chat"
            android:src="@drawable/ic_pin" />

        <ImageButton
            android:id="@+id/btnSelectionArchive"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu_archive_chat"
            android:src="@drawable/ic_archive" />

        <ImageButton
            android:id="@+id/btnSelectionDelete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu_delete_chat"
            android:src="@drawable/ic_delete" />

        <ImageButton
            android:id="@+id/btnSelectionMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"
            android:src="@drawable/ic_more_vert" />

    </LinearLayout>

    <!-- Default SMS Onboarding (Google Messages style) -->
    <include
        android:id="@+id/onboardingContainer"
        layout="@layout/layout_default_sms_onboarding"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
         />

    <LinearLayout
        android:id="@+id/defaultAppBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="?attr/actionBarSize"
        android:background="@color/origin_accent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/default_app_prompt_body"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnSetDefault"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_set_default"
            android:textColor="@android:color/white" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerConversations"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        tools:listitem="@layout/item_conversation" />

    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="@string/empty_conversations"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- FrameLayout wraps both FABs so center_horizontal works -->
    <FrameLayout
        android:id="@+id/fabWrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp">

        <!-- Scroll to top — perfectly centered -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabScrollTop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_horizontal|bottom"
            android:backgroundTint="@color/surface_card"
            android:contentDescription="Scroll to top"
            android:visibility="gone"
            app:fabCustomSize="40dp"
            app:fabSize="mini"
            app:maxImageSize="18dp"
            app:srcCompat="@drawable/ic_arrow_up"
            app:tint="@color/origin_primary"
            app:elevation="4dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <!-- Start chat — right side -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabNewMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:backgroundTint="@color/origin_accent"
            android:contentDescription="@string/action_new_message"
            android:text="Start chat"
            android:textColor="@android:color/white"
            app:icon="@drawable/ic_sms_compose"
            app:iconTint="@android:color/white"
            app:elevation="6dp" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
