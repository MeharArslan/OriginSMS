# Copy this file to local.properties (which is gitignored) and set the
# correct path for your environment.
#
# Termux example (after installing the Android SDK command-line tools):
# sdk.dir=/data/data/com.termux/files/home/android-sdk
#
# Standard Android Studio example:
# sdk.dir=/Users/yourname/Library/Android/sdk
sdk.dir=/path/to/your/android-sdk
