<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/surface_card"
    android:paddingBottom="24dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:layout_gravity="center_horizontal"
        android:background="#30000000"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/text_secondary"/>
    <TextView
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Schedule message"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/opt8am"
        android:background="?attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="24dp">
        <ImageView
            android:background="@drawable/bg_schedule_icon"
            android:padding="10dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_schedule_morning"
            app:tint="@color/origin_primary"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tomorrow morning"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:id="@+id/txt8amTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/opt1pm"
        android:background="?attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="24dp">
        <ImageView
            android:background="@drawable/bg_schedule_icon"
            android:padding="10dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_schedule_afternoon"
            app:tint="@color/origin_accent"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tomorrow afternoon"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:id="@+id/txt1pmTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/opt6pm"
        android:background="?attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="24dp">
        <ImageView
            android:background="@drawable/bg_schedule_icon"
            android:padding="10dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_schedule_evening"
            app:tint="#ff6b35"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tomorrow evening"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:id="@+id/txt6pmTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/optCustom"
        android:background="?attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="24dp">
        <ImageView
            android:background="@drawable/bg_schedule_icon"
            android:padding="10dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_schedule_custom"
            app:tint="@color/origin_primary"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Pick date &amp; time"
            android:layout_weight="1"
            android:layout_marginStart="16dp"/>
    </LinearLayout>
</LinearLayout>
