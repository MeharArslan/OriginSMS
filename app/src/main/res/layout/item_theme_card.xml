<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="6dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTheme"
        android:layout_width="140dp"
        android:layout_height="220dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/cardBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/miniToolbar"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:paddingHorizontal="8dp">
                <View
                    android:background="@drawable/bg_avatar_circle"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:alpha="0.7"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:textSize="8sp"
                    android:textColor="#ffffffff"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Contact"
                    android:layout_weight="1"
                    android:alpha="0.9"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:padding="6dp"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <TextView
                    android:textSize="7sp"
                    android:id="@+id/bubbleReceived"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:maxWidth="90dp"
                    android:text="Hello! ��"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="4dp"/>
                <LinearLayout
                    android:gravity="end"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:textSize="7sp"
                        android:id="@+id/bubbleSent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="90dp"
                        android:text="Hi there! ��"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>
                <TextView
                    android:textSize="7sp"
                    android:id="@+id/bubbleReceived2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="90dp"
                    android:text="How are you?"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/miniInputBar"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:paddingHorizontal="6dp">
                <View
                    android:background="@drawable/bg_input_field"
                    android:layout_width="0dp"
                    android:layout_height="14dp"
                    android:layout_weight="1"
                    android:alpha="0.4"
                    android:layout_marginEnd="4dp"/>
                <View
                    android:id="@+id/miniSendBtn"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:id="@+id/txtThemeCardName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="2"/>
    <TextView
        android:textSize="9sp"
        android:textColor="@color/origin_accent"
        android:gravity="center"
        android:id="@+id/txtThemeSelected"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✓ Applied"/>
</LinearLayout>
